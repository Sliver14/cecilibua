generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Registration {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  whatsapp        String
  location        String
  status          Status   @default(PENDING)
  amount          Float
  transactionNote String?  @unique
  emailSent       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum Status {
  PENDING
  PAID
}
